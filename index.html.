<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Icono de perfume en la pestaña -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🧴</text></svg>">
    <title>Inventario Exclusivo - Zafirah Perfumería</title>
    <style>
        /* --- CSS3: ESTILOS Y DISEÑO VISUAL --- */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-image: url('rene-bohmer-YeUVDKZWSZ4-unsplash.jpg');
            background-size: cover; 
            background-position: center;
            background-attachment: fixed;
            background-color: #0a0a0a; 
            color: #e0e0e0;
            margin: 0; 
            padding: 40px 20px;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
        }
        
        .contenedor {
            background-color: rgba(18, 18, 18, 0.85); 
            width: 100%;
            max-width: 700px;
            padding: 35px;
            border-radius: 12px;
            border: 1px solid #d4af37; 
            box-shadow: 0 15px 40px rgba(212, 175, 55, 0.15);
            backdrop-filter: blur(8px); 
            text-align: center; 
        }
        
        .logo-empresa {
            width: 180px; 
            height: 180px; 
            object-fit: cover; 
            border-radius: 50%; 
            margin: 0 auto 15px auto;
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.4); 
            border: 2px solid #d4af37; 
            display: block; 
        }

        h1 { 
            color: #d4af37; 
            text-transform: uppercase;
            letter-spacing: 3px;
            border-bottom: 1px solid #333;
            padding-bottom: 15px;
            margin-top: 10px;
            font-size: 20px;
        }
        
        .formulario input, .formulario button {
            width: 100%; 
            padding: 14px; 
            margin-top: 15px;
            border-radius: 6px; 
            box-sizing: border-box;
            font-size: 15px;
            text-align: left;
        }
        
        .formulario input {
            background-color: #1e1e1e;
            border: 1px solid #444;
            color: #fff;
        }
        
        .formulario button {
            background: linear-gradient(to right, #bf953f, #fcf6ba, #b38728, #fbf5b7, #aa771c);
            color: #000;
            font-weight: bold; 
            border: none; 
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        table { width: 100%; margin-top: 30px; border-collapse: collapse; }
        th { color: #d4af37; font-size: 14px; text-transform: uppercase; padding: 15px 10px; border-bottom: 1px solid #2a2a2a; }
        td { padding: 15px 10px; border-bottom: 1px solid #2a2a2a; }
        .highlight-total { color: #d4af37; font-weight: bold; font-size: 24px; }
    </style>
</head>
<body>
    <div class="contenedor">
        <img src="31474cf9-6dfb-4cb6-bed3-d2a2204d8802.png" alt="Logo Zafirah Perfumería" class="logo-empresa">
        <h1>Control de Inventario</h1>
        <p style="color: #aaa; font-size: 14px;">Precio base por unidad: <strong style="color: #d4af37;">$20,000 COP</strong></p>
        
        <div class="formulario">
            <input type="text" id="nombreArticulo" placeholder="Nombre de la fragancia">
            <input type="number" id="cantidadArticulo" placeholder="Cantidad que ingresa">
            <button onclick="registrarProducto()">Añadir al Inventario</button>
            <div id="error" style="color: #ff4c4c; margin-top: 10px;"></div>
        </div>

        <table>
            <thead>
                <tr><th>Artículo</th><th>Cant.</th><th>Valor Acumulado</th></tr>
            </thead>
            <tbody id="listaInventario"></tbody>
        </table>
        
        <div style="text-align: right; margin-top: 25px; padding-top: 20px; border-top: 1px solid #333;">
            Total Inventario: <span class="highlight-total" id="totalGlobal">$0</span>
        </div>
    </div>

    <script>
        let inventario = []; 
        const precioBase = 20000; 

        function registrarProducto() {
            let nombre = document.getElementById('nombreArticulo').value;
            let cantidad = parseInt(document.getElementById('cantidadArticulo').value);
            if (nombre.trim() === "" || isNaN(cantidad)) return;

            inventario.push({ nombre, cantidad, valorTotal: cantidad * precioBase });
            actualizarPantalla();
        }

        function actualizarPantalla() {
            let cuerpoTabla = document.getElementById('listaInventario');
            cuerpoTabla.innerHTML = ""; 
            let granTotal = 0; 
            inventario.forEach(item => {
                granTotal += item.valorTotal;
                cuerpoTabla.innerHTML += `<tr><td>${item.nombre}</td><td>${item.cantidad}</td><td>$${item.valorTotal.toLocaleString('es-CO')}</td></tr>`;
            });
            document.getElementById('totalGlobal').innerText = "$" + granTotal.toLocaleString('es-CO');
        }
    </script>
</body>
</html>
